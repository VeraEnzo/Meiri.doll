---
---

<header class="w-full bg-[#fff1b5] border-b-2 border-[#9b1734]/20 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img
        src="/assets/logos/logo-vanilla-bg.png"
        alt="meiri doll"
        class="h-16 w-16 object-contain"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8 text-[#9b1734]">
      <a href="#coleccion" class="text-sm tracking-widest uppercase hover:opacity-60 transition-opacity">
        colección
      </a>
      <a href="#contacto" class="text-sm tracking-widest uppercase hover:opacity-60 transition-opacity">
        contacto
      </a>
      <a
        href="https://www.instagram.com/meiri.doll/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-[#9b1734] text-[#fff1b5] text-sm px-4 py-2 rounded-full hover:bg-[#7a1028] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @meiri.doll
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden text-[#9b1734] p-2"
      aria-label="Abrir menú"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#fff1b5] border-t border-[#9b1734]/20 px-6 pb-4">
    <nav class="flex flex-col gap-4 pt-4 text-[#9b1734]">
      <a href="#coleccion" class="text-sm tracking-widest uppercase" id="mobile-coleccion">colección</a>
      <a href="#contacto" class="text-sm tracking-widest uppercase" id="mobile-contacto">contacto</a>
      <a
        href="https://www.instagram.com/meiri.doll/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 bg-[#9b1734] text-[#fff1b5] text-sm px-4 py-2 rounded-full w-fit"
      >
        @meiri.doll
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  ['mobile-coleccion', 'mobile-contacto'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
