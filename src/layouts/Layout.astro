---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'meiri doll',
  description = 'Indumentaria femenina argentina con estética shoujo y coquette, inspirada en la moda asiática.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff1b5" />
    <link rel="icon" type="image/svg+xml" href="/assets/simbolo/boton.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
